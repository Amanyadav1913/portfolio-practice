<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UI design</title>
</head>
<link rel="stylesheet" href="https://fontawesome.com/">
<!-- <link rel="stylesheet" href="style.css"> -->
<style>
      * {
      padding: 0px;
      margin: 0px;
      box-sizing: border-box;
  }

  body {
      width: 100vw;
      height: 100vh;
      background-color:#0B0B0B;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding-top: 20px;
  }

  .container {
      width: 80%;
      height: 94%;
      background-color: #0B0B0B;
      margin: auto;
      border: 8px solid #B0B0B0B0;

  }

  .navbar {
      width: 90%;
      height: 10%;
      background-color: #070707b0;
      display: flex;
      align-items: center;
      justify-content: space-around;
      margin: auto;
      margin-top: 10px;
  }

  .logo {
      color: #FF6A00;
      font-size: 30px;
      font-weight: 800;

  }

  .about {
      display: flex;
      justify-content: space-evenly;
      align-items: center;
      
  }

  ul li {
      list-style: none;
      display: inline-block;
      margin: 0px 20px;
       width: 80px;
      margin: 10px;

      a {
          text-decoration: none;
          color: #fff;
          font-size: 20px;
          margin: 10px;
          font-family: Georgia, 'Times New Roman', Times, serif;
      }
  }

  button {
      padding: 10px 20px;
      background-color: #FF6A00;
      color: #ffffffe6;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size:15px ;
  }
  .hero-section{
    display: flex;
    margin: auto;
    /* margin-top: 10px; */
  }
  .l-side{
    /* border: 2px solid red; */
    width: 55%;
    height: 544px;
     margin-top: 10px;
     margin-left: 20px;
     color: #ffffffd5;
  }
  .r-side{
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40%;
    /* border: 2px solid white; */
    height: 544px;
     margin-top: 10px;

     img{
        height: 540px;
        object-fit: cover;
     }
  }
  .intro{
    margin-top: 80px;
    margin-left: 40px;

    p{
        font-weight: 700;
        font-size: 14px;
    }

    h1{
        font-size: 30px;
         font-family: 'Times New Roman', Times, serif;
    }
  }
  .skills{
     margin-left: 40px;
     margin-top: 10px;
     font-size: 40px;
     color: #FF6A00;
  }

  .btn{
    display: flex;
    justify-content:space-around;
    width: 60%;
    /* margin-left: 20px; */
    margin-top: 80px;
  }
  
   button1{
     padding: 4px 20px;        
      color: #ffffffbc;
      border: 2px solid rgba(255, 255, 255, 0.993);
      border-radius: 4px;
      font-size: 18px;
      cursor: pointer;
   }

   .card{
    width: 45%;
    height: 50px;
    display: flex;
    align-self: center;
    justify-content: space-around;
    background-color: #3432325a;   
    color: #fff;
    font-size: 15px;
    margin-left: 35px;
    margin-top: 40px;
        p{
            font-size:18px;
            color: #ffffff6d;
        }
        span{
            color: #ff6a00f5;
        }      
}
.icon{
    height: 40px;
    width: 50%;
    /* border: 2px solid; */
    margin-left: 40px;
    margin-top: 10px;
     
    i{
        height: 40px;
        width: 20px;

    }
}
</style>
<body>

    <div class="container">
        <div class="navbar">
            <div class="logo">Logo</div>
            <div class="about">
                <ul>
                    <li><a href="#">Home</a></li>
                    <li><a href="#">About</a></li>
                    <li><a href="#">Services</a></li>
                    <li><a href="#">Portfolio</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>
            <button href="#">Hire me</button>
        </div>
        <div class="hero-section">
            <div class="l-side">
                <div class="intro">
                    <p>Hello, I'm</p>
                    <h1>Aman Yadav</h1>
                </div>
                <div class="skills">
                    <h2>UI / UX designer</h2>
                </div>
                <div class="icon">
                    <i class="fa-brands fa-instagram"><i class="fa-brands fa-instagram"></i></i>

                </div>
                <div class="btn">
                    <button>Hire me</button>
                    <button1>Download cv</button>
                </div>

                <div class="card">
                    <span>5+ 
                        <p>Experience</p>
                    </span>
                    <span>20+
                        <p>Projects</p>
                    </span>
                    <span>80+ 
                        <p>Happy Clients</p>
                    </span>
                </div>
            </div>

            <div class="r-side">
                <img src="Confident pose in dramatic lighting.png" alt="">
            </div>
        </div>
    </div>
